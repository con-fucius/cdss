# Facility Mapper environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=facility-mapper

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://facility_user:facility_pass@localhost:5433/facility_mapper_dev
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Security ─────────────────────────────────────────────────────────
ADMIN_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=

# ── Facility matching ─────────────────────────────────────────────────
# Ambulance speed in km/h for ETA calculation. Default 60 is realistic
# urban/rural Kenya average. Documented in matcher.py.
AMBULANCE_SPEED_KMH=60

# Maximum age (seconds) of in-process BallTree cache before rebuild
# on next request. Default 3600 (1 hour). Set to 0 to disable
# automatic expiry (manual reload only).
FACILITY_CACHE_TTL_SECONDS=3600

# ── Geocoding ─────────────────────────────────────────────────────────
# Nominatim user agent string for geocoding requests.
GEOCODING_USER_AGENT=ambulance-cdss-facility-mapper

# Nominatim request timeout in seconds.
GEOCODING_TIMEOUT_SECONDS=5

# ── Observability ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
