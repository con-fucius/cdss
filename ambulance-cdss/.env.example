# Ambulance CDSS environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=ambulance-cdss

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ambulance_user:ambulance_pass@localhost:5433/ambulance_cdss_dev
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Incident retention (Phase 1.9 — RESOLVED) ─────────────────────────
# Days after incident closure before PII fields are purged. Resolved: 30.
INCIDENT_RETENTION_DAYS=30

# ── External services (Phase 0.3 / 0.4 — confirmed in-house; awaiting
# real API contracts from the service owner, see file headers in
# app/external/) ───────────────────────────────────────────────────────
FACILITY_REGISTRY_BASE_URL=
FACILITY_REGISTRY_API_KEY=
FACILITY_REGISTRY_TIMEOUT_SECONDS=5

EMERGENCY_DISPATCH_BASE_URL=
EMERGENCY_DISPATCH_API_KEY=
EMERGENCY_DISPATCH_TIMEOUT_SECONDS=5

# ── Prehospital drug/item logging (Phase 0.5 — RESOLVED) ──────────────
# Resolved: log every relevant drug or item a unit carries, considers, or
# administers, with no allowlist gate — does not depend on the item
# actually being given. PREHOSPITAL_FORMULARY is deprecated and unused
# by the medication endpoint; see app/config.py::get_prehospital_formulary.
PREHOSPITAL_FORMULARY=

# ── Security ─────────────────────────────────────────────────────────
# Admin API key required for /admin/* endpoints in production.
# Empty string = no key required (development only). Must be set and
# ALLOWED_ORIGINS must be non-wildcard before ENVIRONMENT=production.
ADMIN_API_KEY=

# Comma-separated allowed CORS origins. Empty = '*' (development only).
# Example: https://dispatcher.example.com,https://field.example.com
ALLOWED_ORIGINS=

# ── Triage Ranker (Phase 2.7) ────────────────────────────────────────
TRIAGE_RANKER_BASE_URL=
TRIAGE_RANKER_API_KEY=
TRIAGE_RANKER_TIMEOUT_SECONDS=5

# ── Observability ─────────────────────────────────────────────────────
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_DEFAULT_PER_MINUTE=120
LOG_LEVEL=INFO
