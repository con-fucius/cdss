# ─────────────────────────────────────────────────────────
# Ambulance CDSS — Environment Configuration
# Copy this file to .env and configure for your deployment.
# ─────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────
# "development" or "production". Production enforces strict
# config validation at startup (see config.py::validate_startup_config).
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string. Required for all features.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ambulance_cdss
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Incident Retention ───────────────────────────────────
# Days after incident closure before PII fields are purged.
# Default: 30 days. Set to 0 to disable (blocked in production).
INCIDENT_RETENTION_DAYS=30

# ── PII Purge Scheduler ─────────────────────────────────
# Set to "true" to enable the in-process asyncio purge scheduler
# (runs every 6 hours). Requires DATABASE_URL to be set.
PURGE_SCHEDULE_ENABLED=false

# ── Authentication ───────────────────────────────────────
# JSON string of dispatcher credentials. Format:
# {"username": {"pin_hash": "sha256:salt:hash", "role": "dispatcher"}}
# Empty in development (auth bypassed). Required in production.
DISPATCHER_CREDENTIALS=

# HMAC signing key for session and handoff tokens.
# MUST be changed before production deployment.
HANDOFF_SIGNING_KEY=change-me-before-production

# Hours before a session token expires (default: 8).
SESSION_TOKEN_EXPIRY_HOURS=8

# Admin API key for /admin/* endpoints. Empty = unrestricted (dev only).
ADMIN_API_KEY=

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins. Default: * (dev only).
# Required in production.
ALLOWED_ORIGINS=

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Answer Correction ────────────────────────────────────
# Seconds after submitting a dispatch answer during which
# the dispatcher can correct it (default: 60).
ANSWER_CORRECTION_WINDOW_SECONDS=60

# ── URLs ─────────────────────────────────────────────────
# Base URL for the field UI that paramedics open on their devices.
# Must not be localhost in production.
FIELD_UI_BASE_URL=http://localhost:5501

# Base URL for the receiving hospital handoff page.
# Must not be localhost in production.
HANDOFF_BASE_URL=http://localhost:8000

# ── Facility Registry (Phase 0.3) ────────────────────────
# External service for finding nearest hospital facilities.
# Required in production.
FACILITY_REGISTRY_BASE_URL=
FACILITY_REGISTRY_API_KEY=
FACILITY_REGISTRY_TIMEOUT_SECONDS=5

# ── Emergency Dispatch (Phase 0.4) ───────────────────────
# External service for unit dispatch and admission reporting.
# Required in production.
EMERGENCY_DISPATCH_BASE_URL=
EMERGENCY_DISPATCH_API_KEY=
EMERGENCY_DISPATCH_TIMEOUT_SECONDS=5

# ── Triage Ranker (Phase 2) ─────────────────────────────
# External service for clinical triage enrichment.
# Optional — system degrades to regex-based extraction when unconfigured.
TRIAGE_RANKER_BASE_URL=
TRIAGE_RANKER_API_KEY=
TRIAGE_RANKER_TIMEOUT_SECONDS=5

# ── Formulary (DEPRECATED — Phase 0.5) ──────────────────
# Medication logging is unconditional. This list is now only used
# as suggestions in the field UI, not as an allowlist.
PREHOSPITAL_FORMULARY=
