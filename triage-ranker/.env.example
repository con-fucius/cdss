# Triage Ranker environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=triage-ranker

# ── Security ─────────────────────────────────────────────────────────
ADMIN_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=

# ── spaCy model ───────────────────────────────────────────────────────
# Path to the spaCy model. In Docker, this is /app/models/en_core_web_md.
# In development, set to the installed model path.
SPACY_MODEL_PATH=en_core_web_md

# ── UMLS API (optional) ──────────────────────────────────────────────
# Without this key, the service runs in degraded mode (L4 fallback only).
# Results are still useful but lack canonical SNOMED/ICD-10 codes.
UMLS_API_KEY=
UMLS_API_TIMEOUT_SECONDS=3

# ── Clinical rules ────────────────────────────────────────────────────
# Path to clinical_rules.yaml. In Docker, this is /app/rules/clinical_rules.yaml.
CLINICAL_RULES_PATH=app/rules/clinical_rules.yaml

# ── Cache ─────────────────────────────────────────────────────────────
# SQLite database for L2 persistent cache.
UMLS_CACHE_DB_PATH=cache/umls_cache.db

# ── Observability ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
