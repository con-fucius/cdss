# Copy to .env and fill local secrets.

CDSS_ENV=development
CDSS_PATIENT_SALT=replace-with-at-least-16-random-bytes

DATABASE_URL=postgresql+asyncpg://cdss:cdss@localhost:5432/cdss
CDSS_SESSION_STORAGE_BACKEND=postgres
CDSS_AUDIT_STORAGE_BACKEND=postgres

# Default runtime provider.
QUERY_LLM_PROVIDER=groq
GROQ_API_KEY=
QUERY_LLM_MODEL=qwen/qwen3-32b
GROQ_REASONING_FORMAT=hidden

# Chat should use chunk retrieval only by default. PageIndex remains available
# through /pageindex and the Knowledge Base surface; set auto/always only when
# you deliberately want page summaries injected into chat prompts.
CDSS_CHAT_PAGEINDEX_MODE=off
CDSS_PAGEINDEX_CHAT_TIMEOUT_SECONDS=3

# Optional Puter fallback: set QUERY_LLM_PROVIDER=puter and provide PUTER_AUTH_TOKEN.
PUTER_AUTH_TOKEN=
PUTER_MODEL=openai/gpt-4o-mini
PUTER_OPENAI_BASE_URL=https://api.puter.com/puterai/openai/v1

LANCEDB_PATH=app/lancedb

# Cosmetic local guardrails.
PYTHONDONTWRITEBYTECODE=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Optional live terminology expansion for guideline embedding queries.
CDSS_TERMINOLOGY_QUERY_EXPANSION_ENABLED=false
CDSS_TERMINOLOGY_SHADOW_ENABLED=false
CDSS_TERMINOLOGY_SHADOW_RETRIEVAL_ENABLED=false
CDSS_TERMINOLOGY_SHADOW_TIMEOUT_SECONDS=8

# Optional auto memory distillation when a clinician starts a new conversation.
CDSS_AUTO_MEMORY_DISTILLATION_ENABLED=false

# Optional RxNorm/openFDA drug interaction checks for patient medication lists.
CDSS_DRUG_INTERACTION_CHECK_ENABLED=false
CDSS_DRUG_INTERACTION_CHECK_TIMEOUT_SECONDS=4

# Extraction policy used by ingestion only.
CDSS_DOCLING_MODE=auto
CDSS_DOCLING_MAX_FILE_MB=25
CDSS_DOCLING_MAX_PAGES=120
CDSS_DOCLING_OCR=false
CDSS_DOCLING_TABLE_STRUCTURE=false
